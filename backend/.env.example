# Configuracion del servidor
PORT=3001
NODE_ENV=development

# Configuracion de la base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=stockpro_db

# Configuracion JWT
JWT_SECRET=genera_un_string_aleatorio_de_64_chars_hex
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com

MP_ACCESS_TOKEN=
FRONTEND_URL=

# Cifrado AES-256-CBC para datos sensibles (API keys, etc.)
ENCRYPTION_KEY=genera_un_string_aleatorio_de_64_chars_hex

# IA — fallbacks si no hay claves en la BD (panel superadmin → Integraciones)
# Las claves en BD se almacenan cifradas con ENCRYPTION_KEY
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
AI_DEFAULT_PROVIDER=openai
# OpenAI base URL y modelo. Fallbacks si no se configuran en el panel (Integraciones).
# Para el plan OpenCode Go (key sk- de opencode.ai), usa su endpoint OpenAI-compatible:
#   OPENAI_BASE_URL=https://opencode.ai/zen/v1   y un modelo del plan, p. ej. deepseek-v4-flash
OPENAI_BASE_URL=https://opencode.ai/zen/v1
OPENAI_MODEL=deepseek-v4-flash

# ─────────────────────────────────────────────────────────────
# WhatsApp via Evolution API
# Repositorio de instalación: https://github.com/devalexcode/shell-evolution-api
#
# 1. En el servidor VPS:
#    git clone https://github.com/devalexcode/shell-evolution-api.git
#    cp .env.example .env
#    nano .env   ← define AUTHENTICATION_API_KEY, EVOLUTION_API_PORT, POSTGRESS_PASS
#    chmod +x install.sh && ./install.sh
#
# 2. Copia estos valores desde el .env de ese repositorio:
#    EVOLUTION_API_URL  ← http://<IP_DEL_VPS>:<EVOLUTION_API_PORT>  ej: http://123.45.67.89:8080
#    EVOLUTION_API_KEY  ← el valor de AUTHENTICATION_API_KEY que definiste allá
#    API_BASE_URL       ← URL pública de ESTE backend  ej: https://api.tudominio.com
#                         (necesaria para registrar el webhook en cada instancia)
# ─────────────────────────────────────────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
API_BASE_URL=
